    "# Setup\n",
    "target_name = \"BALBIN\"\n",
    "seed_num = 1\n",
    "redacted_name = \"\"\n",
    "\n",
    "# Logic: replace vowels with the seed number\n",
    "for char in target_name:\n",
    "    if char in \"AEIOU\":\n",
    "        redacted_name += str(seed_num)\n",
    "    else:\n",
    "        redacted_name += char\n",
    "\n",
    "print(f\"Redacted Output: {redacted_name}\")\n"
   ]
